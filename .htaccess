# Impede o Apache de redirecionar pastas para URL com barra (evita loop de redirect)
DirectorySlash Off

# Desabilita listagem de diretórios (evita exposição de arquivos em pastas sem index)
Options -Indexes

RewriteEngine On
RewriteBase /

# 1. Redirecionar URLs com barra final para versão sem barra (exceto raiz)
# Ex: /congresso/ → /congresso
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)/$ /$1 [R=301,L]

# 2. Servir index.html de diretórios sem barra final
# Ex: /congresso → serve congresso/index.html diretamente (sem redirecionar)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+)$ $1/index.html [L]

# 3. Redirecionamento 301 de URLs legadas (da raiz para a nova estrutura)
RewriteRule ^curso-antigo\.html$ /curso/reforma-tributaria [R=301,L]
RewriteRule ^curso-final\.html$ /curso/reforma-tributaria [R=301,L]

# 4. Forçar HTTPS (evita conexões em texto puro / downgrade)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 5. Remover extensão .html das URLs (Clean URLs)
# Se o request não é um diretório
RewriteCond %{REQUEST_FILENAME} !-d
# E o arquivo com extensão .html existe
RewriteCond %{REQUEST_FILENAME}\.html -f
# Sirva o arquivo .html mas mantenha a URL limpa
RewriteRule ^(.*)$ $1.html [L]

# 6. Redirecionar acessos diretos com .html para a versão limpa (Evitar conteúdo duplicado no SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.html
RewriteRule ^/?(.*)\\.html$ /$1 [L,R=301]

# 7. Cabeçalhos de segurança (defesa contra clickjacking, MIME sniffing e downgrade)
<IfModule mod_headers.c>
    # Impede a página de ser embutida em iframes de outros domínios (clickjacking)
    Header always set X-Frame-Options "SAMEORIGIN"
    # Impede o browser de "adivinhar" o content-type (MIME sniffing)
    Header always set X-Content-Type-Options "nosniff"
    # Limita o vazamento da URL de origem para terceiros
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Restringe APIs sensíveis do browser que a landing page não utiliza
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # Força HTTPS por 1 ano (só tem efeito quando servido via HTTPS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>
